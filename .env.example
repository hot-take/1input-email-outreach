# Ocean.io API Settings
OCEAN_API_KEY=your_ocean_api_key_here
OCEAN_API_URL=https://api.ocean.io/v3

# Prospeo API Settings
PROSPEO_API_KEY=your_prospeo_api_key_here

# Eazyreach API Settings
EAZYREACH_API_KEY=your_eazyreach_api_key_here
EAZYREACH_API_URL=https://api.eazyreach.app

# Brevo API Settings (For Email Sending)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=sender@yourdomain.com
BREVO_SENDER_NAME="Your Name"

# General Config
DRY_RUN=false
DB_PATH=outreach_history.db
